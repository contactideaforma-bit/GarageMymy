# Copie ce fichier en ".env.local" et renseigne tes clés.

# --- Supabase (Project Settings > API) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Clé SERVICE ROLE (Project Settings > API > service_role) — SERVEUR uniquement,
# ne PAS préfixer NEXT_PUBLIC. Requise pour la config SMTP (table protégée).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- Anthropic (extraction IA du rapport d'expertise) ---
# Clé sur https://console.anthropic.com  (côté serveur uniquement, ne PAS préfixer NEXT_PUBLIC)
ANTHROPIC_API_KEY=sk-ant-...
# Optionnel : modèle utilisé pour l'extraction
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Envoi des emails ---
# Méthode recommandée : SMTP, configuré DANS l'appli (Profil du garage > Envoi des emails).
# Les identifiants SMTP sont stockés en base (table protégée) — rien à mettre ici.
# Gmail : créer un « mot de passe d'application » (compte avec validation en 2 étapes).
#
# Alternative (optionnelle) : Resend, utilisé en repli si aucun SMTP n'est configuré.
# RESEND_API_KEY=re_...
# RESEND_FROM=Garage MYMY <devis@mondomaine.fr>

# --- Connexion bancaire directe (optionnel, à venir) ---
# Agrégateur DSP2 Enable Banking (https://enablebanking.com) : sandbox gratuite,
# "restricted production" sur tes propres comptes, contrat+KYB pour la prod.
# Tant que ces clés sont absentes, l'onglet Banque fonctionne par import CSV.
# ENABLE_BANKING_APP_ID=...
# ENABLE_BANKING_PRIVATE_KEY=...

# --- Relances automatiques (cron Vercel, optionnel) ---
# Secret partage : Vercel > Settings > Environment Variables. Vercel Cron
# l'envoie automatiquement en Authorization: Bearer sur /api/relances-auto.
# CRON_SECRET=une-longue-chaine-aleatoire
